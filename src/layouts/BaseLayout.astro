---
import { Image } from 'astro:assets';

interface Props {
  title: string;
}

const { title } = Astro.props;

const navItems = [
  { name: "ホーム", href: "/" },
  { name: "マニュアル", href: "/manual" },
  { name: "免責事項", href: "/disclaimer" },
];
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - GuRain</title>
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="apple-touch-icon" sizes="192x192" href="/apple-touch-icon.png" />
    <link
      rel="icon"
      type="image/png"
      href="/favicon-512x512.png"
      sizes="512x512"
    />

    <!-- Open Graph Tags -->
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="iOS/macOS対応グラニュラシンセサイザーAUv3プラグイン。最大128グレイン、MIDI/Generativeモード、ADSRエンベロープ、LFOモーフィング機能。"
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content="/images/og-image.png" />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Card Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta
      name="twitter:description"
      content="iOS/macOS対応グラニュラシンセサイザーAUv3プラグイン。最大128グレイン、MIDI/Generativeモード、ADSRエンベロープ、LFOモーフィング機能。"
    />
    <meta name="twitter:image" content="/images/og-image.png" />

    <!-- Font Preconnect for Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- Sticky Header with Glass Effect -->
    <header class="site-header">
      <div class="header-container">
        <nav class="header-nav">
          <!-- Logo -->
          <a href="/" class="logo-link">
            <Image
              src="/images/logo.png"
              alt="GuRain Logo"
              width={64}
              height={64}
              class="logo-img"
            />
          </a>

          <!-- Desktop Navigation -->
          <div class="desktop-nav">
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class="nav-link"
                >
                  {item.name}
                </a>
              ))
            }
            <a
              href="https://buy.polar.sh/polar_cl_mnTvugsC3aKUzHZNFDkQBV1FQXT8UUumGD2uc43E6lx?discount_code=INTRO2026"
              target="_blank"
              class="btn btn-ghost btn-sm"
            >
              購入する
            </a>
          </div>

          <!-- Mobile Menu Button -->
          <button
            id="mobile-menu-button"
            class="mobile-menu-button"
            aria-label="メニューを開く"
            aria-expanded="false"
          >
            <svg
              class="hamburger-icon"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </nav>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="mobile-menu hidden">
          <div class="mobile-menu-content">
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class="mobile-nav-link"
                >
                  {item.name}
                </a>
              ))
            }
            <a
              href="https://buy.polar.sh/polar_cl_mnTvugsC3aKUzHZNFDkQBV1FQXT8UUumGD2uc43E6lx?discount_code=INTRO2026"
              target="_blank"
              class="btn btn-primary btn-sm"
            >
              購入する
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="site-main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-container">
        <div class="footer-main">
          <div class="footer-logo">
            <Image
              src="/images/logo.png"
              alt="GuRain Logo"
              width={64}
              height={64}
              class="footer-logo-img"
            />
            <span class="footer-logo-text">GuRain</span>
          </div>
          <div class="footer-nav">
            <a href="/" class="footer-link">ホーム</a>
            <a href="/manual" class="footer-link">マニュアル</a>
            <a href="/disclaimer" class="footer-link">免責事項</a>
          </div>
        </div>
        <div class="footer-bottom">
          &copy; 2026 GuRain. All rights reserved.
        </div>
      </div>
    </footer>

    <!-- Mobile Menu Toggle Script -->
    <script>
      const menuButton = document.getElementById("mobile-menu-button");
      const mobileMenu = document.getElementById("mobile-menu");

      menuButton?.addEventListener("click", () => {
        const isExpanded = menuButton.getAttribute("aria-expanded") === "true";
        menuButton.setAttribute("aria-expanded", String(!isExpanded));
        mobileMenu?.classList.toggle("hidden");
      });

      // Intersection Observer for fade-in animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
      );

      document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

<style is:global>
  /* Import global styles */
  @import "../styles/global.css";
  @import "../styles/design-system.css";
</style>

<style>
  /* Header Styles */
  .site-header {
    position: fixed;
    top: 0;
    z-index: 50;
    width: 100%;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
  }

  .header-container {
    max-width: 80rem;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  @media (min-width: 640px) {
    .header-container {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }

  .header-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .logo-link {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: opacity 0.2s ease;
  }

  .logo-link:hover {
    opacity: 0.8;
  }

  .logo-img {
    height: 2rem;
    width: auto;
  }

  /* Desktop Navigation - Always visible on desktop */
  .desktop-nav {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .desktop-nav {
      display: flex;
    }
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-accent-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Mobile Menu Button - Hidden on desktop */
  .mobile-menu-button {
    display: block;
    padding: 0.5rem;
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .mobile-menu-button:hover {
    background: var(--color-mist-light);
  }

  @media (min-width: 768px) {
    .mobile-menu-button {
      display: none;
    }
  }

  .hamburger-icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  /* Mobile Menu - Hidden on desktop */
  .mobile-menu {
    display: block;
    padding-bottom: 1rem;
  }

  .mobile-menu.hidden {
    display: none;
  }

  @media (min-width: 768px) {
    .mobile-menu {
      display: none !important;
    }
  }

  .mobile-menu-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .mobile-nav-link {
    color: var(--color-text-primary);
    text-decoration: none;
    font-weight: 500;
    padding: 0.5rem 0;
    transition: color 0.2s ease;
  }

  .mobile-nav-link:hover {
    color: var(--color-accent-primary);
  }

  /* Footer Styles */
  .site-footer {
    border-top: 1px solid rgba(216, 236, 244, 0.5);
    background: var(--color-mist-lightest);
    padding: 3rem 0;
  }

  .footer-container {
    max-width: 80rem;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  @media (min-width: 640px) {
    .footer-container {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }

  .footer-main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .footer-main {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-logo-img {
    height: 2rem;
    width: auto;
    opacity: 0.8;
  }

  .footer-logo-text {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  /* Footer navigation - Always horizontal on desktop */
  .footer-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    font-size: 0.875rem;
  }

  @media (min-width: 768px) {
    .footer-nav {
      flex-direction: row;
      gap: 1.5rem;
    }
  }

  .footer-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-accent-primary);
  }

  .footer-bottom {
    margin-top: 2rem;
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
  }

  /* Main content with header padding */
  .site-main {
    min-height: 100vh;
    padding-top: 4rem;
  }
</style>
