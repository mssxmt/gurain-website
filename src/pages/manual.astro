---
// Manual Page for GuRain
// User manual with table of contents and detailed sections

import BaseLayout from "../layouts/BaseLayout.astro";
import ManualSection from "../components/ManualSection.astro";
import ManualSubSection from "../components/ManualSubSection.astro";
import ParameterTable from "../components/ParameterTable.astro";
import RainEffect from "../components/RainEffect.astro";

const metaDescription =
  "GuRainグラニュラシンセサイザーの詳細な使用マニュアル。グローバルパラメータ、グレインエンジン、LFO機能、使用例、トラブルシューティングを網羅。";

const tocSections = [
  { name: "はじめに", href: "#introduction" },
  { name: "インターフェース", href: "#interface" },
  { name: "グローバルパラメータ", href: "#global-parameters" },
  { name: "グレインエンジン", href: "#grain-engine" },
  { name: "LFO機能", href: "#lfo" },
  { name: "使用例", href: "#examples" },
  { name: "プリセット機能", href: "#presets" },
  { name: "トラブルシューティング", href: "#troubleshooting" },
];

const globalParameters = [
  {
    name: "gain",
    range: "0.0 - 1.0",
    description: "マスターゲイン。全体的な出力音量を制御します。",
  },
  {
    name: "grainPitch",
    range: "-24.0 to +24.0 semitones",
    description:
      "グローバルピッチオフセット。全グレインのピッチをセミトーン単位で調整します。",
  },
  {
    name: "playbackMode",
    range: "0 = MIDI, 1 = Generative",
    description:
      "再生モードの切り替え。MIDIモードではMIDIノートでグレインを生成、Generativeモードでは自動生成します。",
  },
  {
    name: "attackTime",
    range: "0.001 - 2.0s",
    description:
      "ADSRエンベロープのアタックタイム。ノートオンから最大音量に達するまでの時間。",
  },
  {
    name: "decayTime",
    range: "0.001 - 2.0s",
    description:
      "ADSRエンベロープのディケイタイム。最大音量からサステインレベルに達するまでの時間。",
  },
  {
    name: "sustainLevel",
    range: "0.0 - 1.0",
    description:
      "ADSRエンベロープのサステインレベル。ノートが押されている間の維持音量。",
  },
  {
    name: "releaseTime",
    range: "0.001 - 5.0s",
    description:
      "ADSRエンベロープのリリースタイム。ノートオフから無音になるまでの時間。",
  },
];

const regionParameters = [
  {
    name: "grainDensity",
    range: "0.0 - 1.0",
    description: "グレイン密度。グレインの生成頻度を制御します。",
  },
  {
    name: "grainDuration",
    range: "0.01 - 2.0s",
    description: "グレイン持続時間。各グレインの再生時間を設定します。",
  },
  {
    name: "grainPosition",
    range: "0.0 - 1.0",
    description:
      "グレイン位置。オーディオバッファ内の再生位置（0.0 = 先頭、1.0 = 末尾）。",
  },
  {
    name: "pitchSpread",
    range: "0.0 - 2.0 octaves",
    description:
      "ピッチスプレッド。グレインのピッチのばらつき具合をオクターブ単位で設定します。",
  },
  {
    name: "positionSpread",
    range: "0.0 - 1.0",
    description:
      "位置スプレッド。グレインの開始位置のばらつき具合を設定します。",
  },
  {
    name: "panSpread",
    range: "0.0 - 1.0",
    description:
      "パンスプレッド。グレインのステレオパンのばらつき具合を設定します。",
  },
];

const lfoParameters = [
  {
    name: "lfoTarget",
    range:
      "off / gain / density / duration / position / pitch / positionSpread / panSpread",
    description: "LFO変調ターゲット。LFOで変調するパラメータを選択します。",
  },
  {
    name: "lfoType",
    range: "0.0 - 5.0",
    description:
      "LFO波形タイプ。0.0（Sine）から5.0（SineRandom）までの連続的なモーフィングが可能です。",
  },
  {
    name: "lfoBpmSync",
    range: "false / true",
    description: "BPM同期モード。DAWのテンポに同期するかどうかを設定します。",
  },
  {
    name: "lfoDepth",
    range: "0.0 - 1.0",
    description: "LFOデプス。変調の深さを制御します。",
  },
  {
    name: "lfoFrequency",
    range: "0.0 - 1.0",
    description:
      "LFO周波数。BPM同期モードでは16thノートから16小節までの範囲になります。",
  },
];
---

<BaseLayout title="GuRain 使用マニュアル">
  <meta name="description" content={metaDescription} />
  <div class="manual-page relative">
    <RainEffect />
    <!-- Page Title -->
    <div class="page-header relative z-10">
      <h1 class="page-title">GuRain 使用マニュアル</h1>
      <p class="page-subtitle">
        GuRainグラニュラシンセサイザーの詳細な使用ガイド
      </p>
    </div>

    <!-- Table of Contents -->
    <div
      id="toc-container"
      class="toc-container glass-card-heavy relative z-10"
    >
      <div
        class="flex items-center justify-between p-4 cursor-pointer"
        id="toc-header"
      >
        <h2 id="toc-title" class="toc-title">目次</h2>
        <button
          id="toc-toggle"
          class="text-text-primary hover:text-accent-primary transition-colors"
          type="button"
        >
          <svg
            id="toc-chevron"
            class="w-6 h-6 transform transition-transform duration-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
      </div>
      <nav id="toc-nav" class="toc-nav">
        {
          tocSections.map((section) => (
            <a href={section.href} class="toc-link">
              {section.name}
            </a>
          ))
        }
      </nav>
    </div>

    <script is:inline>
      let tocExpanded = false;
      function toggleToc() {
        const nav = document.getElementById("toc-nav");
        const chevron = document.getElementById("toc-chevron");
        tocExpanded = !tocExpanded;
        if (tocExpanded) {
          nav.style.maxHeight = "500px";
          nav.style.opacity = "1";
          nav.classList.remove("hidden");
          chevron.classList.remove("rotate-180");
          chevron.classList.remove("hidden");
        } else {
          nav.style.maxHeight = "0";
          nav.style.opacity = "0";
          nav.classList.add("hidden");
          chevron.classList.add("rotate-180");
          chevron.classList.remove("hidden");
        }
      }

      document.addEventListener("DOMContentLoaded", () => {
        const tocHeader = document.getElementById("toc-header");
        const nav = document.getElementById("toc-nav");
        const chevron = document.getElementById("toc-chevron");

        nav.style.maxHeight = "0";
        nav.style.opacity = "0";
        nav.classList.add("hidden");
        chevron.classList.add("rotate-180");
        chevron.classList.remove("hidden");

        tocHeader.addEventListener("click", (e) => {
          toggleToc();
        });
      });

      window.addEventListener("scroll", () => {
        const c = document.getElementById("toc-container");
        const t = document.getElementById("toc-title");
        const n = document.getElementById("toc-nav");
        const ch = document.getElementById("toc-chevron");
        if (window.scrollY > 100) {
          c.classList.remove("p-6");
          c.classList.add("py-2", "px-3");
          t.classList.add("text-sm");
          t.classList.remove("text-2xl");
          n.classList.add("hidden");
          ch.classList.add("hidden");
        } else {
          c.classList.add("p-6");
          c.classList.remove("py-2", "px-3");
          t.classList.remove("text-sm");
          t.classList.add("text-2xl");
          if (tocExpanded) n.classList.remove("hidden");
          ch.classList.remove("hidden");
        }
      });
    </script>

    <!-- Manual Content -->
    <article class="manual-content relative z-10">
      <!-- Section 1: Introduction -->
      <ManualSection title="はじめに" id="introduction" sectionNumber={1}>
        <ManualSubSection title="GuRainとは">
          <p>
            GuRainは、iOS/macOS対応の高度なグラニュラシンセサイザーAUv3プラグインです。
            音源を小さな「グレイン」というセグメントに分割し、それらを重ね合わせて音を生成するグラニュラ合成技法を採用しています。
          </p>
          <p>
            最大128個のグレインを同時再生し、MIDIモードとGenerativeモードの2つの再生モードをサポートしています。
            また、最大8つの独立したリージョンを管理でき、それぞれのリージョンで異なるパラメータ設定が可能です。
          </p>
        </ManualSubSection>

        <ManualSubSection title="主な特徴">
          <ul>
            <li>128グレインプール（√N正規化で音圧制御）</li>
            <li>2再生モード（MIDIモードとGenerativeモード）</li>
            <li>8リージョン対応</li>
            <li>ADSRエンベロープ（Attack、Decay、Sustain、Release）</li>
            <li>6種類のLFO波形連続モーフィング</li>
            <li>BPM同期機能</li>
            <li>58種類のグラデーションプリセット</li>
            <li>音声反応型背景アニメーション</li>
          </ul>
        </ManualSubSection>

        <ManualSubSection title="システム要件">
          <ul>
            <li>macOS 14以上のApple Silicon搭載Mac（Intel Macは非対応）</li>
          </ul>
        </ManualSubSection>

        <ManualSubSection title="インストール方法">
          <ol>
            <li>dmgファイルをダブルクリックで開きます</li>
            <li>開いたウィンドウでGuRain.appをApplicationsフォルダにドラッグ＆ドロップします</li>
            <li>初回起動時に開けない場合は、右クリック（またはControl+クリック）から「開く」を選択してください</li>
          </ol>
        </ManualSubSection>
      </ManualSection>

      <!-- Section 2: Interface -->
      <ManualSection title="インターフェース" id="interface" sectionNumber={2}>
        <ManualSubSection title="メイン画面">
          <p>
            GuRainのメイン画面は、グローバルパラメータエリアとリージョンエリアで構成されています。
            グローバルパラメータでは全体の設定を管理し、リージョンエリアでは各リージョンごとの詳細設定を行います。
          </p>
        </ManualSubSection>

        <ManualSubSection title="グローバルパラメータエリア">
          <p>
            画面上部にはグローバルパラメータが配置されています。これらのパラメータはすべてのリージョンに影響します。
          </p>
          <p>主なグローバルパラメータには以下があります：</p>
          <ul>
            <li>マスターゲイン（出力音量）</li>
            <li>グローバルピッチオフセット</li>
            <li>再生モード切り替え</li>
            <li>ADSRエンベロープ</li>
          </ul>
        </ManualSubSection>

        <ManualSubSection title="リージョンエリア">
          <p>
            画面下部には最大8つのリージョンが表示されます。各リージョンは独立したパラメータ設定を持つことができ、
            複雑なサウンドデザインを可能にします。
          </p>
        </ManualSubSection>
      </ManualSection>

      <!-- Section 3: Global Parameters -->
      <ManualSection
        title="グローバルパラメータ"
        id="global-parameters"
        sectionNumber={3}
      >
        <ManualSubSection>
          <p>
            グローバルパラメータは、すべてのリージョンに適用される全体的な設定です。
            これらのパラメータはメイン画面の上部で調整できます。
          </p>
        </ManualSubSection>

        <ParameterTable parameters={globalParameters} />
      </ManualSection>

      <!-- Section 4: Grain Engine -->
      <ManualSection
        title="グレインエンジン"
        id="grain-engine"
        sectionNumber={4}
      >
        <ManualSubSection title="グラニュラ合成の仕組み">
          <p>
            グラニュラ合成は、音源を小さな「グレイン」というセグメント（通常数ミリ秒から数百ミリ秒）に分割し、
            それらを重ね合わせて音を生成する技法です。GuRainは最大128個のグレインを同時再生可能です。
          </p>
          <p>
            グレインはHanning窓関数で包まれ、境界でのアーティファクトを低減しています。
            また、複数のグレインが同時再生される場合、音圧を防ぐために√N正規化が自動的に適用されます。
          </p>
        </ManualSubSection>

        <ManualSubSection title="リージョンパラメータ">
          <p>各リージョンには以下のパラメータがあり、個別に設定できます：</p>
        </ManualSubSection>

        <ParameterTable parameters={regionParameters} />
      </ManualSection>

      <!-- Section 5: LFO -->
      <ManualSection title="LFO機能" id="lfo" sectionNumber={5}>
        <ManualSubSection title="LFOとは">
          <p>
            LFO（低周波オシレータ）は、パラメータを周期的に変調するために使用されます。
            GuRainのLFOは高度な機能を持ち、6種類の波形間で連続的にモーフィング可能です。
          </p>
        </ManualSubSection>

        <ManualSubSection title="連続モーフィング波形">
          <p>
            LFOタイプは0.0から5.0の範囲で連続的に変化し、以下の波形をモーフィングします：
          </p>
          <ul>
            <li>0.0: Sine（正弦波）</li>
            <li>1.0: Sawtooth（のこ歯状波）</li>
            <li>2.0: Square（矩形波）</li>
            <li>3.0: SquareRandom（矩形波 + ランダム）</li>
            <li>4.0: SawtoothRandom（のこ歯状波 + ランダム）</li>
            <li>5.0: SineRandom（正弦波 + ランダム）</li>
          </ul>
        </ManualSubSection>

        <ManualSubSection title="BPM同期モード">
          <p>
            BPM同期モードを有効にすると、DAWのテンポに同期してLFOが動作します。
            16thノートから16小節までの広範囲な同期をサポートしています。
          </p>
        </ManualSubSection>

        <ParameterTable parameters={lfoParameters} />
      </ManualSection>

      <!-- Section 6: Examples -->
      <ManualSection title="使用例" id="examples" sectionNumber={6}>
        <ManualSubSection title="基本的な使用方法">
          <ol>
            <li>オーディオファイルをロードします</li>
            <li>グローバルパラメータを調整します（ゲイン、ピッチなど）</li>
            <li>
              MIDIキーボードで演奏するか、Generativeモードで自動生成を開始します
            </li>
            <li>リージョンパラメータを調整してサウンドをカスタマイズします</li>
          </ol>
        </ManualSubSection>

        <ManualSubSection title="アンビエントなパッドサウンドを作成する">
          <ul>
            <li>Generativeモードに設定します</li>
            <li>grainDensityを低めに設定します（0.2〜0.4）</li>
            <li>grainDurationを長めに設定します（0.5〜1.5秒）</li>
            <li>pitchSpreadを中程度に設定します（0.5〜1.0オクターブ）</li>
            <li>ADSRエンベロープを設定して、緩やかな変化を付けます</li>
          </ul>
        </ManualSubSection>

        <ManualSubSection title="リズミックなテクスチャを作成する">
          <ul>
            <li>MIDIモードに設定します</li>
            <li>grainDensityを高めに設定します（0.6〜0.9）</li>
            <li>grainDurationを短めに設定します（0.05〜0.2秒）</li>
            <li>positionSpreadを中程度に設定します（0.3〜0.6）</li>
            <li>LFOでグレイン密度を変調して動的な変化を付けます</li>
          </ul>
        </ManualSubSection>
      </ManualSection>

      <!-- Section 7: Presets -->
      <ManualSection title="プリセット機能" id="presets" sectionNumber={7}>
        <ManualSubSection title="プリセットの保存とロード">
          <p>
            presetsボタンからプリセットの保存とロードができます。
            保存されるのはマスターゲイン以外の全ての設定です。
            音声データも保存されるため、ロードするだけですぐにサウンドを再現できます。
          </p>
        </ManualSubSection>

        <ManualSubSection title="エクスポート/インポート機能">
          <p>
            作成したプリセットは.gurain拡張子のファイル形式でエクスポートできます。
            インポート機能を使用することで、他のデバイスとプリセットを共有したり、バックアップとして保存したりすることができます。
          </p>
        </ManualSubSection>
      </ManualSection>

      <!-- Section 8: Troubleshooting -->
      <ManualSection
        title="トラブルシューティング"
        id="troubleshooting"
        sectionNumber={8}
      >
        <ManualSubSection title="音が出ない場合">
          <ul>
            <li>
              DAWのオーディオ出力がミュートになっていないか確認してください
            </li>
            <li>マスターゲイン（gain）が0になっていないか確認してください</li>
            <li>
              オーディオファイルが正常にロードされているか確認してください
            </li>
            <li>
              MIDIモードの場合、MIDIキーボードまたはDAWからMIDIが送られているか確認してください
            </li>
          </ul>
        </ManualSubSection>

        <ManualSubSection title="グレインが生成されない場合">
          <ul>
            <li>
              Generativeモードの場合、grainDensityが0になっていないか確認してください
            </li>
            <li>MIDIモードの場合、ノートが送られているか確認してください</li>
            <li>
              grainDurationが極端に短くないか確認してください（最低0.01秒）
            </li>
          </ul>
        </ManualSubSection>

        <ManualSubSection title="サウンドがクリップする場合">
          <ul>
            <li>マスターゲインを下げてください</li>
            <li>
              複数のリージョンを使用している場合、各リージョンのゲインを下げてください
            </li>
            <li>DAWの出力メーターを確認してください</li>
          </ul>
        </ManualSubSection>

        <ManualSubSection title="CPU負荷が高い場合">
          <ul>
            <li>grainDensityを下げてください</li>
            <li>リージョンの数を減らしてください</li>
            <li>grainDurationを短くしてください</li>
            <li>オーディオバッファサイズを大きくしてください</li>
          </ul>
        </ManualSubSection>

        <ManualSubSection title="LFOが期待通りに動作しない場合">
          <ul>
            <li>lfoTargetが適切に設定されているか確認してください</li>
            <li>lfoDepthが0になっていないか確認してください</li>
            <li>
              BPM同期モードを使用している場合、DAWのテンポが正しく設定されているか確認してください
            </li>
          </ul>
        </ManualSubSection>

        <ManualSubSection title="オーディオデバイス切替時の注意">
          <p>
            DAWやシステム設定でオーディオデバイスを切り替えると、再生が停止することがあります。
            この場合、プリセットの再読み込みを行うことで復旧できます。
          </p>
        </ManualSubSection>
      </ManualSection>
    </article>

    <!-- Back to Top Button -->
    <button
      id="back-to-top"
      onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
      class="back-to-top relative z-20"
      aria-label="トップに戻る"
    >
      <svg
        class="w-5 h-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
      </svg>
    </button>
  </div>
</BaseLayout>

<style>
  .manual-page {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-md);
    position: relative;
    z-index: 1;
    min-height: 100vh;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 300;
    color: var(--color-text-primary);
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-sm);
  }

  .page-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
  }

  /* Table of Contents */
  .toc-container {
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-2xl);
    transition: all 0.3s ease;
  }

  .toc-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-text-primary);
  }

  .toc-nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    padding: var(--spacing-md);
    max-height: 500px;
    overflow: hidden;
    opacity: 1;
    transition: all 0.3s ease;
  }

  .toc-nav.hidden {
    max-height: 0;
    opacity: 0;
    padding-top: 0;
    padding-bottom: 0;
  }

  .toc-link {
    padding: 0.75rem 1rem;
    color: var(--color-text-body);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
    font-size: 0.95rem;
  }

  .toc-link:hover {
    background: var(--color-mist-light);
    color: var(--color-accent-primary);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .toc-nav {
      grid-template-columns: 1fr;
    }
  }

  /* Manual content spacing */
  .manual-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  /* Back to top button */
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    background: var(--color-accent-primary);
    color: var(--color-mist-lightest);
    border: none;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .back-to-top.visible {
    opacity: 1;
    visibility: visible;
  }

  .back-to-top:hover {
    background: var(--color-accent-soft);
    transform: translateY(-2px);
    box-shadow: var(--shadow-xl);
  }

  @media (max-width: 640px) {
    .manual-page {
      padding: var(--spacing-lg) var(--spacing-sm);
    }

    .back-to-top {
      bottom: 1rem;
      right: 1rem;
      width: 2.5rem;
      height: 2.5rem;
    }
  }
</style>

<script>
  // Back to top button visibility
  const backToTop = document.getElementById("back-to-top");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 500) {
      backToTop?.classList.add("visible");
    } else {
      backToTop?.classList.remove("visible");
    }
  });
</script>
