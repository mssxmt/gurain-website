---
// 404 Page for GuRain
// Custom 404 error page with friendly message

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ページが見つかりません - GuRain">
  <div class="min-h-screen gradient-organic flex items-center justify-center px-4">
    <div class="max-w-2xl mx-auto text-center space-y-8">
      <!-- 404 Number -->
      <div class="relative">
        <h1 class="text-9xl md:text-[12rem] font-heading font-bold text-moss/20 absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
          404
        </h1>
        <div class="relative z-10 pt-16 md:pt-20">
          <!-- Friendly Illustration Placeholder -->
          <div class="w-full max-w-md mx-auto aspect-square bg-white/50 rounded-3xl flex items-center justify-center border-2 border-dashed border-moss/30 mb-8">
            <svg
              class="w-32 h-32 text-terracotta opacity-60"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
          </div>

          <!-- Main Heading -->
          <h2 class="text-4xl md:text-5xl font-heading font-bold text-text-dark text-shadow-soft mb-4">
            ページが見つかりません
          </h2>

          <!-- Message -->
          <p class="text-lg md:text-xl font-body text-text-dark opacity-90 max-w-lg mx-auto mb-8">
            お探しのページは存在しないか、移動された可能性があります。
          </p>

          <!-- Home Button -->
          <a
            href="/"
            class="inline-flex items-center px-8 py-4 bg-terracotta text-text-light font-heading font-semibold rounded-lg hover:bg-terracotta/90 transition-all transform hover:scale-105 shadow-lg"
          >
            <svg
              class="w-5 h-5 mr-2"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
              />
            </svg>
            ホームに戻る
          </a>

          <!-- Additional Links -->
          <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center text-text-dark opacity-75">
            <a href="/manual" class="hover:text-terracotta transition-colors">
              マニュアルを見る
            </a>
            <span class="hidden sm:inline text-moss">|</span>
            <a href="/disclaimer" class="hover:text-terracotta transition-colors">
              免責事項
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Organic gradient background */
  .gradient-organic {
    background: linear-gradient(135deg, var(--color-sage) 0%, var(--color-cream) 100%);
  }
</style>
