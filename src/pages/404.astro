---
// 404 Page for GuRain - Ethereal Mist Theme
// Custom 404 error page with friendly message

import BaseLayout from '../layouts/BaseLayout.astro';

const metaDescription = 'お探しのページが見つかりません。GuRainホームページまたはマニュアルへ戻ってください。';
---

<BaseLayout title="ページが見つかりません - GuRain">
  <meta name="description" content={metaDescription} />
  <div class="not-found-page">
    <div class="not-found-content">
      <!-- Background 404 -->
      <div class="not-found-bg">404</div>

      <div class="not-found-inner">
        <!-- Illustration -->
        <div class="not-found-icon">
          <svg
            class="w-16 h-16"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
        </div>

        <!-- Heading -->
        <h1 class="not-found-title">ページが見つかりません</h1>

        <!-- Message -->
        <p class="not-found-message">
          お探しのページは存在しないか、移動された可能性があります。
        </p>

        <!-- Home Button -->
        <a
          href="/"
          class="btn btn-primary btn-lg"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
            />
          </svg>
          ホームに戻る
        </a>

        <!-- Additional Links -->
        <div class="not-found-links">
          <a href="/manual">マニュアルを見る</a>
          <span class="divider">|</span>
          <a href="/disclaimer">免責事項</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found-page {
    min-height: calc(100vh - 5rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-xl) var(--spacing-md);
    background: linear-gradient(
      180deg,
      var(--color-mist-lightest) 0%,
      var(--color-mist-light) 100%
    );
  }

  .not-found-content {
    max-width: 32rem;
    text-align: center;
    position: relative;
  }

  .not-found-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: clamp(8rem, 25vw, 16rem);
    font-weight: 700;
    color: var(--color-accent-subtle);
    opacity: 0.3;
    font-family: var(--font-display);
    line-height: 1;
    z-index: 0;
    pointer-events: none;
  }

  .not-found-inner {
    position: relative;
    z-index: 1;
  }

  .not-found-icon {
    width: 8rem;
    height: 8rem;
    margin: 0 auto var(--spacing-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--glass-light);
    backdrop-filter: blur(10px);
    border-radius: 50%;
    color: var(--color-accent-primary);
    box-shadow: var(--shadow-md);
  }

  .not-found-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 300;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-md);
    letter-spacing: 0.05em;
  }

  .not-found-message {
    font-size: 1.125rem;
    color: var(--color-text-body);
    margin-bottom: var(--spacing-lg);
    max-width: 25rem;
    margin-left: auto;
    margin-right: auto;
  }

  .not-found-links {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    align-items: center;
    margin-top: var(--spacing-lg);
    color: var(--color-text-secondary);
    font-size: 0.9375rem;

    @media (min-width: 640px) {
      flex-direction: row;
      gap: var(--spacing-md);
    }
  }

  .not-found-links a {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .not-found-links a:hover {
    color: var(--color-accent-primary);
  }

  .divider {
    display: none;

    @media (min-width: 640px) {
      display: block;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .not-found-button:hover {
      transform: none;
    }
  }
</style>
