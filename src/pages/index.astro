---
// Landing Page for GuRain
// Main homepage with Hero, Features, and CTA sections

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import FeatureCards from "../components/FeatureCards.astro";

const metaDescription =
  "GuRainはiOS/macOS対応グラニュラシンセサイザーAUv3プラグイン。最大128グレイン、MIDI/Generativeモード、ADSRエンベロープ、LFOモーフィング機能。";
---

<BaseLayout title="GuRain - グラニュラシンセサイザー">
  <meta name="description" content={metaDescription} />
  <meta
    name="keywords"
    content="granular, synthesizer, audio, music production, AUv3, iOS, macOS, MIDI, generative"
  />
  <!-- Hero Section -->
  <Hero />

  <!-- App Overview Section -->
  <section class="overview-section section-spacing-sm">
    <div class="container">
      <div class="overview-content">
        <h2 class="overview-title">GuRainについて</h2>
        <p class="overview-text">
          GuRainは、macOS専用デスクトップグラニュラーシンセサイザーです。
          音源を小さな「グレイン」というセグメントに分割し、それらを重ね合わせて音を生成するグラニュラ合成技法を採用しています。
          最大128個のグレインを同時再生し、MIDIモードとGenerativeモードの2つの再生モードをサポートしています。
        </p>
      </div>
    </div>
  </section>

  <!-- Feature Cards Section -->
  <FeatureCards />

  <!-- System Requirements Section -->
  <section class="requirements-section section-spacing-sm">
    <div class="container">
      <div class="requirements-content">
        <h2 class="requirements-title">システム要件</h2>
        <ul class="requirements-list">
          <li>macOS 14以上</li>
          <li>Apple Silicon搭載Mac（Intel Macは非対応）</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section section-spacing">
    <div class="container">
      <div class="cta-content">
        <h2 class="cta-title">始めましょう</h2>
        <p class="cta-subtitle">
          GuRainの詳細な機能と使用方法をマニュアルで確認してください。
        </p>
        <div class="cta-buttons">
          <a href="/manual" class="cta-button cta-button-primary">
            マニュアルを見る
          </a>
          <a href="#" target="_blank" class="cta-button cta-button-secondary">
            購入する
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Overview Section */
  .overview-section {
    background: var(--color-mist-lightest);
  }

  .overview-content {
    max-width: 4xl;
    text-align: center;
  }

  .overview-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 300;
    color: var(--color-text-primary);
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-md);
  }

  .overview-text {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-body);
    line-height: 1.8;
    max-width: 60rem;
    margin: 0 auto;
  }

  /* Requirements Section */
  .requirements-section {
    background: var(--color-mist-lightest);
  }

  .requirements-content {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
  }

  .requirements-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--color-text-primary);
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-lg);
  }

  .requirements-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    align-items: center;
  }

  .requirements-list li {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    color: var(--color-text-body);
    line-height: 1.6;
  }

  /* CTA Section */
  .cta-section {
    background: linear-gradient(
      180deg,
      var(--color-mist-medium) 0%,
      var(--color-mist-dark) 100%
    );
    position: relative;
    overflow: hidden;
  }

  /* Subtle rain in CTA background */
  .cta-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(
      to bottom,
      transparent,
      rgba(120, 160, 190, 0.05),
      transparent
    );
    pointer-events: none;
  }

  .cta-content {
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 300;
    color: var(--color-text-primary);
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-md);
  }

  .cta-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-body);
    max-width: 40rem;
    margin: 0 auto var(--spacing-lg);
  }

  .cta-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    align-items: center;

    @media (min-width: 640px) {
      flex-direction: row;
      justify-content: center;
    }
  }

  .cta-button {
    padding: 1rem 2rem;
    border-radius: var(--radius-md);
    font-weight: 500;
    font-size: 1rem;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .cta-button-primary {
    background: var(--color-accent-primary);
    color: var(--color-mist-lightest);
  }

  .cta-button-primary:hover {
    background: var(--color-accent-soft);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .cta-button-secondary {
    background: var(--color-off-white);
    color: var(--color-text-primary);
  }

  .cta-button-secondary:hover {
    background: var(--color-mist-light);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-button:hover {
      transform: none;
    }
  }
</style>
