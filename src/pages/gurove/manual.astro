    <script>
      // Responsive TOC — collapsed by default on mobile, always open on desktop.
      (() => {
        const toc = document.getElementById("g-toc");
        const toggle = document.getElementById("g-toc-toggle");
        if (!toc || !toggle) return;
        const mq = window.matchMedia("(min-width: 1024px)");
        const setOpen = (open) => {
          toc.classList.toggle("is-open", open);
          toggle.setAttribute("aria-expanded", String(open));
        };
        // Desktop = open, mobile = closed; re-sync when crossing the breakpoint.
        const apply = () => setOpen(mq.matches);
        apply();
        mq.addEventListener("change", apply);
        toggle.addEventListener("click", () => {
          setOpen(!toc.classList.contains("is-open"));
        });
      })();
    </script>
