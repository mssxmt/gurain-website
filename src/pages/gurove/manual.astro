              <ParameterTable params={mcpToolsParams} />
              <h4 class="g-subsec__title" style="font-size:1.05rem; margin-top:1.75rem;">Resources（ナレッジベース）</h4>
              <ParameterTable params={mcpResourcesParams} />
            </ManualSubSection>
          </ManualSection>

        </div>
      </div>
