---
// Feature Cards Grid - Ethereal Mist Theme
// Responsive grid layout (3/2/1 columns) for feature cards

import FeatureCard from './FeatureCard.astro';

const features = [
  {
    title: '128グレインプール',
    description: '最大128個のグレインを同時再生可能。√N正規化で音圧を適切に制御します。',
    imageSrc: '/images/grain.png',
    imageAlt: '128グレインプールのUI',
  },
  {
    title: '2再生モード',
    description: 'MIDIモードとGenerativeモードの2つの再生モードをサポート。演奏と自動生成のどちらも可能。',
    imageSrc: '/images/playmode.png',
    imageAlt: '再生モード選択UI',
  },
  {
    title: '8リージョン対応',
    description: '最大8つの独立したリージョンを管理。それぞれのリージョンで異なるパラメータ設定が可能。',
    imageSrc: '/images/region.png',
    imageAlt: 'リージョン管理UI',
  },
  {
    title: 'ADSRエンベロープ',
    description: 'Attack、Decay、Sustain、Releaseの4段階で音量を制御する精密なエンベロープ。',
    imageSrc: '/images/adsr.png',
    imageAlt: 'ADSRエンベロープコントロール',
  },
  {
    title: '6種波形LFOモーフィング',
    description: 'Sine、Sawtooth、Squareなど6種類の波形を連続的にモーフィング可能。',
    imageSrc: '/images/lfo.png',
    imageAlt: 'LFOモーフィングUI',
  },
  {
    title: 'リバーブ',
    description: '内蔵リバーブ効果で空間的な広がりを演出。湿り量とサイズを調整可能。',
    imageSrc: '/images/reverb.png',
    imageAlt: 'リバーブエフェクト',
  },
  {
    title: '40システムプリセット',
    description: '40種類のシステムプリセットをプリインストール。ユーザープリセットの保存も可能で、オリジナル設定を保管できます。',
    imageSrc: '/images/presets.png',
    imageAlt: 'システムプリセット',
  },
  {
    title: '58種類グラデーションプリセット',
    description: '58種類の美しいグラデーションプリセットをプリインストール。視覚的表現の幅を広げます。',
    imageSrc: '/images/theme.png',
    imageAlt: 'グラデーションプリセット',
  },
];
---

<section class="features-section section-spacing">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">主要な特徴</h2>
      <p class="section-subtitle">微細な粒子が奏でる無限の可能性</p>
    </div>

    <div class="features-grid">
      {features.map((feature, index) => (
        <FeatureCard
          title={feature.title}
          description={feature.description}
          imageSrc={feature.imageSrc}
          imageAlt={feature.imageAlt}
          class={`fade-in stagger-${index + 1}`}
          data-stagger={String(index + 1)}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background: linear-gradient(
      180deg,
      var(--color-mist-light) 0%,
      var(--color-mist-medium) 100%
    );
    position: relative;
  }

  /* Subtle rain in background */
  .features-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(
      to bottom,
      transparent,
      rgba(120, 160, 190, 0.05),
      transparent
    );
    pointer-events: none;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
    position: relative;
    z-index: 1;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 300;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text-primary);
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
  }

  /* Responsive Grid Layout */
  .features-grid {
    display: grid;
    gap: var(--spacing-lg);
    position: relative;
    z-index: 1;
  }

  /* Mobile: 1 column */
  @media (max-width: 639px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Tablet: 2 columns */
  @media (min-width: 640px) and (max-width: 1023px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Desktop: 3 columns */
  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Large desktop: 4 columns (optional) */
  @media (min-width: 1280px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>

<script>
  // Intersection Observer for fade-in animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    }
  );

  document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
</script>
