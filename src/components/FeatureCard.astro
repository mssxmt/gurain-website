---
// Feature Card Component
// Reusable card component with organic design, glass-effect, and hover animations
// Props: title, description

interface Props {
  title: string;
  description: string;
  imageSrc?: string;
  imageAlt?: string;
}

const { title, description, imageSrc, imageAlt = '' } = Astro.props;
---

<div class="feature-card glass-card p-0 transition-transform duration-300">
  <!-- Image placeholder -->
  <div class="aspect-[4/3] overflow-hidden rounded-t-[inherit] relative">
    {imageSrc ? (
      <img src={imageSrc} alt={imageAlt} class="w-full h-full object-cover" />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-blue-deep/10 to-sky-light/30 flex flex-col items-center justify-center p-6">
        <!-- Image placeholder icon -->
        <svg
          class="w-16 h-16 mb-4 text-blue-deep/40"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <rect
            x="3"
            y="3"
            width="18"
            height="18"
            rx="2"
            ry="2"
            stroke-width="1.5"
          />
          <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor" stroke="none" />
          <path
            d="M21 15l-5-5L5 21"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        <p class="text-sm text-text-dark/60 font-body">画像を追加予定</p>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-6 rounded-b-[inherit]">
    <h3 class="text-xl font-heading font-bold text-text-dark mb-3">{title}</h3>
    <p class="text-text-dark font-body opacity-80 leading-relaxed">{description}</p>
  </div>
</div>

<style>
  .feature-card {
    /* Organic border-radius */
    border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;

    /* Glass-effect */
    background: rgba(244, 241, 222, 0.6);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(107, 142, 35, 0.1);

    /* Transition for hover lift */
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .feature-card:hover {
    /* Subtle lift animation */
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(44, 62, 45, 0.15);
  }

  /* Add some texture/variation to make cards look more organic */
  .feature-card:nth-child(odd) {
    border-radius: 40% 60% 70% 30% / 60% 30% 70% 40%;
  }

  .feature-card:nth-child(even) {
    border-radius: 60% 40% 30% 70% / 40% 60% 30% 70%;
  }

  .feature-card:nth-child(3n) {
    border-radius: 30% 70% 60% 40% / 70% 30% 60% 40%;
  }

  .feature-card:nth-child(4n) {
    border-radius: 50% 50% 50% 50% / 50% 50% 50% 50%;
  }
</style>
