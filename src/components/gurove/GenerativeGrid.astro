---
// GenerativeGrid — the signature.
// An 8-lane × 16-step LED grid that actually simulates the product's
// generative algorithms (Euclidean / ProbDensity / LFSR / Markov /
// CellularAutomaton / RandomWalk + fixed Kick/Hihat voices) and plays
// itself. No dependencies. Cells are rendered server-side; JS only
// toggles classes. Prefers-reduced-motion → static pose.
// (AlgorithmShowcase lists all 9 algorithms including fixed Snare.)

const STEPS = 16

// Each lane = one drum voice driven by one algorithm.
// accent lanes light in mycelium (green), the rest in ember (amber).
const LANES = [
  { id: 'ch1', label: 'KICK',  algo: 'EUCLIDEAN',     accent: false },
  { id: 'ch2', label: 'SNARE', algo: 'PROBDENSITY',   accent: false },
  { id: 'ch3', label: 'PERC',  algo: 'LFSR',          accent: false },
  { id: 'ch4', label: 'TOM',   algo: 'MARKOV',        accent: false },
  { id: 'ch5', label: 'FX',    algo: 'CELLULAR',      accent: true  },
  { id: 'ch6', label: 'BASS',  algo: 'RANDOMWALK',    accent: true  },
  { id: 'ch7', label: 'HAT',   algo: 'FIXED-HAT',     accent: false },
  { id: 'ch8', label: 'KICK2', algo: 'FIXED-KICK',    accent: false },
]
---

<div class="g-genwrap" data-gurove-grid>
  <div class="g-readout g-readout--top">
    <span>SEED <b data-gurove-seed>04831</b></span>
    <span>ALGO <span class="g-readout__algo" data-gurove-algo>9 ALGORITHMS</span></span>
    <span>STEP <b data-gurove-step>00</b>/16</span>
    <span><b data-gurove-bpm>120.0</b> BPM</span>
    <span>LOOP <b data-gurove-loop>00</b></span>
  </div>

  <div class="g-grid" role="img" aria-label="Generative step sequencer playing algorithms across 8 drum lanes">
    {LANES.map((lane) => (
      <Fragment>
        <div class="g-grid__lane-label">{lane.label}</div>
        {Array.from({ length: STEPS }, (_, s) => (
          <div
            class={`g-cell${lane.accent ? ' g-cell--accent' : ''}`}
            data-lane={lane.id}
            data-step={s}
          ></div>
        ))}
      </Fragment>
    ))}
  </div>

  <p class="g-genwrap__caption g-mono">
    8 voices · 9 algorithms · self-evolving every 2 loops · same seed reproduces the same groove
  </p>
</div>

<style>
  .g-genwrap {
    position: relative;
    border: 1px solid var(--g-rule);
    border-radius: 12px;
    background: linear-gradient(180deg, var(--g-panel) 0%, var(--g-asfalt-2) 100%);
    padding: 1.1rem 1.1rem 1.3rem;
    box-shadow: 0 30px 60px -30px rgba(0, 0, 0, 0.8);
  }
  .g-genwrap::after {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(236, 231, 220, 0.14), transparent);
    border-radius: 12px 12px 0 0;
  }

  .g-readout--top {
    padding: 0 0.5rem 0.9rem;
    border-bottom: 1px solid var(--g-rule-soft);
    margin-bottom: 0.8rem;
  }

  .g-genwrap__caption {
    margin-top: 1rem;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    line-height: 1.6;
    text-align: center;
    opacity: 0.85;
  }

  /* keep the grid cells comfortably sized on narrow screens */
  @media (max-width: 640px) {
    .g-grid { gap: 3px; padding: 10px; }
    .g-grid__lane-label { font-size: 0.55rem; padding-right: 4px; }
    .g-readout--top { font-size: 0.62rem; gap: 0.4rem 1rem; }
  }
</style>

<script>
  // ---- deterministic PRNG (mulberry32) — same seed, same series ----
  function mulberry32(a: number) {
    return function () {
      a |= 0; a = (a + 0x6d2b79f5) | 0;
      let t = Math.imul(a ^ (a >>> 15), 1 | a);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }

  // ---- the algorithms (faithful simplifications of SPECIFICATION §7) ----

  // Euclidean — Bjorklund even distribution. Deterministic.
  function euclidean(steps: number, hits: number, offset = 0): number[] {
    const p = new Array(steps).fill(0);
    for (let i = 0; i < hits; i++) p[Math.round((i * steps) / hits) % steps] = 1;
    const rot = offset % steps;
    return [...p.slice(rot), ...p.slice(0, rot)];
  }

  // ProbDensity — each step an independent probability. seed-dependent.
  function probDensity(steps: number, density: number, rng: () => number): number[] {
    return Array.from({ length: steps }, () => (rng() < density ? 1 : 0));
  }

  // LFSR — tapped shift register pseudo-random. seed-dependent.
  function lfsr(steps: number, length: number, taps: number[], seed: number): number[] {
    let reg = (seed >>> 0) || 1;
    const out: number[] = [];
    for (let i = 0; i < steps; i++) {
      let bit = 0;
      for (const t of taps) bit ^= (reg >> t) & 1;
      reg = (reg >> 1) | (bit << (length - 1));
      out.push(reg & 1);
    }
    return out;
  }

  // Markov — Nth-order: previous N steps form the state, each state owns a
  // "next step is on" probability, biased globally. seed-dependent.
  function markov(steps: number, order: number, bias: number, rng: () => number): number[] {
    const states = 1 << order;
    const table: number[] = [];
    for (let s = 0; s < states; s++) {
      table[s] = Math.max(0, Math.min(1, rng() + (bias - 0.5)));
    }
    const out = new Array(steps).fill(0);
    let state = 0;
    for (let i = 0; i < steps; i++) {
      out[i] = rng() < table[state] ? 1 : 0;
      state = ((state << 1) | out[i]) & (states - 1);
    }
    return out;
  }

  // Cellular Automaton — 1D, Wolfram rule. Width = steps. Evolves per loop.
  function caNext(rule: number, row: number[]): number[] {
    const n = row.length;
    return row.map((_, i) => {
      const l = row[(i - 1 + n) % n];
      const c = row[i];
      const r = row[(i + 1) % n];
      return (rule >> ((l << 2) | (c << 1) | r)) & 1;
    });
  }
  function caRow(steps: number): number[] {
    const row = new Array(steps).fill(0);
    row[Math.floor(steps / 2)] = 1;
    return row;
  }

  // Random Walk — a wandering cursor marks active steps. seed-dependent.
  function randomWalk(steps: number, stepSize: number, bounds: number, rng: () => number): number[] {
    const out = new Array(steps).fill(0);
    let pos = Math.floor(rng() * bounds);
    for (let i = 0; i < steps; i++) {
      out[pos % steps] = 1;
      pos += (rng() < 0.5 ? -1 : 1) * stepSize;
      pos = ((pos % bounds) + bounds) % bounds;
    }
    return out;
  }

  // Fixed patterns — drum skeletons (kick/hihat). seed-dependent:
  // the backbone stays, but placement breathes with the seed.
  function fixedHat(rng: () => number): number[] {
    return Array.from({ length: 16 }, (_, i) => {
      const on = i % 2 === 1;            // 8th-note backbone
      if (on) return rng() < 0.85 ? 1 : 0;
      return rng() < 0.12 ? 1 : 0;
    });
  }
  function fixedKick(rng: () => number): number[] {
    return Array.from({ length: 16 }, (_, i) => {
      const on = i % 4 === 0;            // 4th-note backbone
      if (on) return rng() < 0.9 ? 1 : 0;
      return rng() < 0.08 ? 1 : 0;
    });
  }

  type Lane = { id: string; algo: string; accent: boolean; pattern: number[] };

  // ---- build lanes with per-algorithm params ----
  function buildLanes(seed: number): Lane[] {
    const rng = mulberry32(seed);
    return [
      { id: 'ch1', algo: 'EUCLIDEAN',   accent: false, pattern: euclidean(16, 5, 0) },
      { id: 'ch2', algo: 'PROBDENSITY', accent: false, pattern: probDensity(16, 0.5, rng) },
      { id: 'ch3', algo: 'LFSR',        accent: false, pattern: lfsr(16, 15, [0, 1], 0xa1b2 | seed) },
      { id: 'ch4', algo: 'MARKOV',      accent: false, pattern: markov(16, 2, 0.5, rng) },
      { id: 'ch5', algo: 'CELLULAR',    accent: true,  pattern: caRow(16) },
      { id: 'ch6', algo: 'RANDOMWALK',  accent: true,  pattern: randomWalk(16, 3, 16, rng) },
      { id: 'ch7', algo: 'FIXED-HAT',   accent: false, pattern: fixedHat(rng) },
      { id: 'ch8', algo: 'FIXED-KICK',  accent: false, pattern: fixedKick(rng) },
    ];
  }

  // ---- driver ----
  const wrap = document.querySelector<HTMLElement>('[data-gurove-grid]');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (wrap) {
    const cells = wrap.querySelectorAll<HTMLElement>('.g-cell');
    const seedEl = wrap.querySelector<HTMLElement>('[data-gurove-seed]');
    const algoEl = wrap.querySelector<HTMLElement>('[data-gurove-algo]');
    const stepEl = wrap.querySelector<HTMLElement>('[data-gurove-step]');
    const bpmEl = wrap.querySelector<HTMLElement>('[data-gurove-bpm]');
    const loopEl = wrap.querySelector<HTMLElement>('[data-gurove-loop]');

    let seed = 4831;
    let lanes = buildLanes(seed);
    let step = 0;
    let loop = 0;
    const STEP_MS = 125; // 120bpm 16th

    const cellAt = (laneIdx: number, s: number) => cells[laneIdx * 16 + s];

    function paint() {
      for (let l = 0; l < lanes.length; l++) {
        const row = lanes[l].pattern;
        for (let s = 0; s < 16; s++) {
          const el = cellAt(l, s);
          if (!el) continue;
          const on = row[s] === 1;
          const ph = s === step;
          el.classList.toggle('is-on', on);
          el.classList.toggle('is-playhead', ph);
        }
      }
      if (stepEl) stepEl.textContent = String(step).padStart(2, '0');
    }

    function advance() {
      step++;
      if (step >= 16) {
        step = 0;
        loop++;
        // every 2 loops: re-seed random family, evolve CA one generation
        if (loop % 2 === 0) {
          seed = Math.floor(Math.random() * 65535);
          lanes = buildLanes(seed);
        } else {
          // CA evolves each loop (organic growth)
          const caLane = lanes[4];
          caLane.pattern = caNext(30, caLane.pattern);
        }
        if (seedEl) seedEl.textContent = String(seed).padStart(5, '0');
        if (loopEl) loopEl.textContent = String(loop).padStart(2, '0');
      }
      paint();
    }

    function setReadout() {
      if (seedEl) seedEl.textContent = String(seed).padStart(5, '0');
      if (algoEl) algoEl.textContent = '9 ALGORITHMS';
      if (bpmEl) bpmEl.textContent = '120.0';
      if (loopEl) loopEl.textContent = String(loop).padStart(2, '0');
    }

    setReadout();
    paint();

    if (!reduce) {
      let last = performance.now();
      let acc = 0;
      const tick = (now: number) => {
        acc += now - last;
        last = now;
        while (acc >= STEP_MS) {
          acc -= STEP_MS;
          advance();
        }
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }
  }
</script>
