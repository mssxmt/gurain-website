---
// FeatureRow — the zig-zag DNA inherited from GuRain's FeatureCards.
// imageSrc is optional: until product screenshots exist, a labelled
// placeholder frame occupies the slot so images drop in later without
// touching markup. Same prop pattern as GuRain's FeatureCard.

interface Props {
  index: string        // §03 ...
  eyebrow: string
  title: string
  description: string
  points?: string[]
  imageSrc?: string
  imageAlt?: string
  placeholderLabel?: string
  reverse?: boolean
}

const {
  index,
  eyebrow,
  title,
  description,
  points = [],
  imageSrc,
  imageAlt = '',
  placeholderLabel = 'UI Screenshot',
  reverse = false,
} = Astro.props
---

<div class={`g-row${reverse ? ' g-row--reverse' : ''} g-reveal`}>
  <!-- Visual slot -->
  <div class="g-row__visual">
    {imageSrc ? (
      <img src={imageSrc} alt={imageAlt} loading="lazy" />
    ) : (
      <div class="g-placeholder">
        <div class="g-placeholder__frame" aria-hidden="true"></div>
        <span class="g-placeholder__label">{placeholderLabel}</span>
      </div>
    )}
  </div>

  <!-- Copy slot -->
  <div class="g-row__copy">
    <p class="g-index">{index}</p>
    <p class="g-eyebrow">{eyebrow}</p>
    <h3 class="g-display g-row__title">{title}</h3>
    <p class="g-lead">{description}</p>
    {points.length > 0 && (
      <ul class="g-row__points">
        {points.map((pt) => (
          <li>{pt}</li>
        ))}
      </ul>
    )}
  </div>
</div>

<style>
  .g-row__copy {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-items: flex-start;
  }
  .g-row__title {
    font-size: clamp(1.9rem, 4vw, 2.8rem);
  }
  .g-row__points {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-width: 34rem;
  }
  .g-row__points li {
    position: relative;
    padding-left: 1.5rem;
    font-size: 0.92rem;
    color: var(--g-bone-dim);
    line-height: 1.6;
  }
  .g-row__points li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--g-ember);
    box-shadow: 0 0 6px var(--g-ember-glow);
  }
</style>
