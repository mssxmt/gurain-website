---
// Parameter Table Component - Ethereal Mist Theme
// Displays parameter information in a glass-morphism table format

interface Parameter {
  name: string;
  range: string;
  description: string;
}

interface Props {
  parameters: Parameter[];
}

const { parameters } = Astro.props;
---

<div class="parameter-table-wrapper">
  <table class="parameter-table">
    <thead>
      <tr class="table-header">
        <th class="table-head">パラメータ</th>
        <th class="table-head">範囲</th>
        <th class="table-head">説明</th>
      </tr>
    </thead>
    <tbody>
      {parameters.map((param, index) => (
        <tr class="table-row">
          <td class="table-cell table-cell-code">
            <code>{param.name}</code>
          </td>
          <td class="table-cell table-cell-range">
            {param.range}
          </td>
          <td class="table-cell table-cell-description">
            {param.description}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .parameter-table-wrapper {
    margin: var(--spacing-md) 0;
    overflow-x: auto;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .parameter-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-family: var(--font-body);
  }

  .table-header {
    background: var(--color-mist-light);
  }

  .table-head {
    padding: var(--spacing-sm) var(--spacing-md);
    text-align: left;
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--color-text-primary);
    letter-spacing: 0.025em;
    border-bottom: 2px solid var(--color-accent-subtle);
  }

  .table-row {
    background: var(--glass-light);
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    transition: background 0.2s ease;
  }

  .table-row:last-child {
    border-bottom: none;
  }

  .table-row:hover {
    background: var(--glass-medium);
  }

  .table-cell {
    padding: var(--spacing-sm) var(--spacing-md);
    font-size: 0.9375rem;
    vertical-align: middle;
  }

  .table-cell-code code {
    font-family: 'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', Consolas, monospace;
    font-size: 0.875rem;
    color: var(--color-accent-primary);
    background: var(--color-mist-light);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }

  .table-cell-range {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    width: 25%;
    max-width: 200px;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .table-cell-description {
    color: var(--color-text-body);
    line-height: 1.6;
    width: auto;
  }

  /* Responsive table */
  @media (max-width: 768px) {
    .table-head,
    .table-cell {
      padding: var(--spacing-xs) var(--spacing-sm);
      font-size: 0.8125rem;
    }

    .table-cell-code code {
      font-size: 0.75rem;
      padding: 0.125rem 0.375rem;
    }
  }
</style>
