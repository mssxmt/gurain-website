---
// Manual Sub-Section Component
// Subsection container with optional title and content area
// Props: title (optional), id (optional for anchor linking)

interface Props {
  title?: string;
  id?: string;
}

const { title, id } = Astro.props;
---

<div
  class:id={id}
  class="mb-8 last:mb-0 scroll-mt-20"
>
  {title && (
    <h3 class="text-2xl md:text-3xl font-heading font-semibold text-text-dark mb-4 text-shadow-soft">
      {title}
    </h3>
  )}
  <div class="prose prose-lg max-w-none">
    <slot />
  </div>
</div>

<style>
  div {
    scroll-margin-top: 5rem;
  }

  /* Prose-like styling for content */
  .prose {
    color: var(--color-text-dark);
    font-family: var(--font-body);
    line-height: 1.7;
  }

  .prose p {
    margin-bottom: 1rem;
  }

  .prose ul,
  .prose ol {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose strong {
    font-weight: 600;
    color: var(--color-terracotta);
  }

  .prose em {
    font-style: italic;
  }

  .prose code {
    background: rgba(244, 241, 222, 0.8);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-family: monospace;
    font-size: 0.9em;
  }
</style>
